PORT=3001

# Anthropic API key for ClawBot agent execution
ANTHROPIC_API_KEY=sk-ant-...

# Stacks network: devnet | testnet | mainnet
STACKS_NETWORK=devnet

# Stacks API URL (devnet: clarinet integrate spins this up at :3999)
STACKS_API_URL=http://localhost:3999

# Hot wallet mnemonic — deployer account from backend/settings/Devnet.toml
# On testnet/mainnet, use your actual deployer wallet mnemonic
HOT_WALLET_MNEMONIC=<deployer mnemonic from Devnet.toml>

# Contract addresses — format: <deployer-stx-address>.<contract-name>
# Devnet deployer is always: ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
AGENT_REGISTRY_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.agent-registry
TASK_ESCROW_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.task-escrow
REPUTATION_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.reputation
USDCX_CONTRACT=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM.mock-usdcx

# CORS: allow requests from the frontend
FRONTEND_URL=http://localhost:3000
